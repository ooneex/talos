{
  "name": "@talosjs/feature-flag",
  "description": "Define and evaluate feature flags as injectable, named toggles with descriptions and dynamic enablement",
  "version": "1.1.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsgo --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/container": "workspace:^"
  },
  "keywords": [
    "bun",
    "feature-flag",
    "feature-flags",
    "feature-toggle",
    "talos",
    "toggle",
    "typescript"
  ]
}
