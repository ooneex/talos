{
  "name": "@talosjs/html",
  "description": "HTML parsing and DOM manipulation toolkit powered by Cheerio — extract, transform, and query HTML content with a jQuery-like API",
  "version": "1.1.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsgo --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/exception": "workspace:^",
    "@talosjs/http-status": "workspace:^",
    "cheerio": "^1.1.2"
  },
  "keywords": [
    "bun",
    "cheerio",
    "dom",
    "html",
    "markup",
    "talos",
    "parser",
    "template",
    "typescript"
  ]
}
