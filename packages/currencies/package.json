{
  "name": "@talosjs/currencies",
  "description": "Comprehensive currency dataset with ISO 4217 codes, symbols, names, and TypeScript type definitions for financial and e-commerce applications",
  "version": "1.1.2",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsc --noEmit && bunx biome lint"
  },
  "devDependencies": {
    "@talosjs/types": "workspace:^"
  },
  "keywords": [
    "bun",
    "currencies",
    "currency",
    "finance",
    "money",
    "talos",
    "typescript"
  ]
}
