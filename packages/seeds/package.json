{
  "name": "@talosjs/seeds",
  "description": "Database seeding framework for populating initial data, fixtures, and test datasets with execution logging and idempotent operations",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --force --production --access public"
  },
  "dependencies": {
    "@talosjs/container": "workspace:^",
    "@talosjs/logger": "workspace:^",
    "@talosjs/utils": "workspace:^"
  },
  "devDependencies": {
    "@talosjs/exception": "workspace:^",
    "@talosjs/app-env": "workspace:^"
  },
  "keywords": [
    "bun",
    "database",
    "fixtures",
    "talos",
    "seeding",
    "seeds",
    "typescript"
  ]
}
