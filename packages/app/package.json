{
  "name": "@talosjs/app",
  "description": "Full-featured application framework for Bun — orchestrates routing, middleware pipelines, dependency injection, caching, logging, and WebSocket support in a modular architecture",
  "version": "1.1.3",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsgo --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/app-env": "workspace:^",
    "@talosjs/cache": "workspace:^",
    "@talosjs/container": "workspace:^",
    "@talosjs/controller": "workspace:^",
    "@talosjs/cron": "workspace:^",
    "@talosjs/exception": "workspace:^",
    "@talosjs/feature-flag": "workspace:^",
    "@talosjs/http-request": "workspace:^",
    "@talosjs/http-response": "workspace:^",
    "@talosjs/http-status": "workspace:^",
    "@talosjs/logger": "workspace:^",
    "@talosjs/middleware": "workspace:^",
    "@talosjs/rate-limit": "workspace:^",
    "@talosjs/role": "workspace:^",
    "@talosjs/routing": "workspace:^",
    "@talosjs/socket": "workspace:^",
    "@talosjs/socket-client": "workspace:^",
    "@talosjs/translation": "workspace:^",
    "@talosjs/types": "workspace:^",
    "@talosjs/utils": "workspace:^",
    "@talosjs/validation": "workspace:^"
  },
  "devDependencies": {
    "@talosjs/permission": "workspace:^",
    "@talosjs/module": "workspace:^"
  },
  "keywords": [
    "application",
    "bun",
    "framework",
    "talos",
    "typescript",
    "web-app"
  ]
}
