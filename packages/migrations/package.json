{
  "name": "@talosjs/migrations",
  "description": "Database migration runner with versioned schema changes, rollback support, execution logging, and container-aware lifecycle management",
  "version": "1.1.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsgo --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/container": "workspace:^"
  },
  "devDependencies": {
    "@talosjs/exception": "workspace:^"
  },
  "keywords": [
    "bun",
    "database",
    "migrations",
    "talos",
    "schema",
    "typescript",
    "versioning"
  ]
}
