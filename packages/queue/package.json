{
  "name": "@talosjs/queue",
  "description": "Background job queue powered by BullMQ and Redis — decorator-registered workers with retries, progress tracking, and job lifecycle events",
  "version": "1.1.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsgo --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/container": "workspace:^",
    "@talosjs/exception": "workspace:^",
    "@talosjs/http-status": "workspace:^",
    "bullmq": "^5.78.1"
  },
  "devDependencies": {
    "@talosjs/app-env": "workspace:^"
  },
  "keywords": [
    "bun",
    "talos",
    "queue",
    "typescript"
  ]
}
