{
  "name": "@talosjs/validation",
  "description": "Type-safe validation framework powered by ArkType — define schemas with built-in constraints, custom rules, and JSON Schema generation",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./constraints": {
      "import": {
        "types": "./dist/constraints/index.d.ts",
        "default": "./dist/constraints/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "lint": "tsgo --noEmit && bunx biome lint",
    "npm:publish": "bun publish --tolerate-republish --force --production --access public"
  },
  "dependencies": {
    "@talosjs/app-env": "workspace:^",
    "@talosjs/currencies": "workspace:^",
    "@talosjs/translation": "workspace:^",
    "arktype": "^2.1.29"
  },
  "keywords": [
    "arktype",
    "bun",
    "constraints",
    "talos",
    "schema",
    "typescript",
    "validation",
    "validator"
  ]
}
