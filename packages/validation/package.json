      "import": {
        "types": "./dist/constraints/AssertFirstName.d.ts",
        "default": "./dist/constraints/AssertFirstName.js"
      }
    },
    "./constraints/AssertHexaColor": {
      "import": {
        "types": "./dist/constraints/AssertHexaColor.d.ts",
        "default": "./dist/constraints/AssertHexaColor.js"
      }
    },
    "./constraints/AssertHostname": {
      "import": {
        "types": "./dist/constraints/AssertHostname.d.ts",
        "default": "./dist/constraints/AssertHostname.js"
      }
