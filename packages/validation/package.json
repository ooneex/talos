{
  "name": "@talosjs/validation",
  "description": "Type-safe validation framework powered by ArkType — define schemas with built-in constraints, custom rules, and JSON Schema generation",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./constraints": {
      "import": {
        "types": "./dist/constraints/index.d.ts",
        "default": "./dist/constraints/index.js"
      }
    },
    "./constraints/AssertAppEnv": {
      "import": {
        "types": "./dist/constraints/AssertAppEnv.d.ts",
        "default": "./dist/constraints/AssertAppEnv.js"
      }
    },
    "./constraints/AssertChatQuery": {
