        "types": "./dist/constraints/AssertChatQuery.d.ts",
        "default": "./dist/constraints/AssertChatQuery.js"
      }
    },
    "./constraints/AssertCountryCode": {
      "import": {
        "types": "./dist/constraints/AssertCountryCode.d.ts",
        "default": "./dist/constraints/AssertCountryCode.js"
      }
    },
