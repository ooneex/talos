{
  "name": "@talosjs/http-request",
  "description": "HTTP request abstraction with URL parsing, query parameters, language detection, header management, and multipart file upload support",
  "version": "1.1.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsc --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/http-header": "workspace:^",
    "@talosjs/http-request-file": "workspace:^",
    "@talosjs/url": "workspace:^",
    "accept-language-parser": "^1.5.0"
  },
  "devDependencies": {
    "@talosjs/translation": "workspace:^",
    "@talosjs/types": "workspace:^",
    "@types/accept-language-parser": "^1.5.8"
  },
  "keywords": [
    "bun",
    "http",
    "http-request",
    "talos",
    "request",
    "typescript",
    "web"
  ]
}
