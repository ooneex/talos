{
  "name": "@talosjs/json",
  "description": "JSON file loader and parser with streaming support and generator-based iteration",
  "version": "1.1.1",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsc --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/exception": "workspace:*",
    "@talosjs/http-status": "workspace:*"
  },
  "keywords": [
    "bun",
    "json",
    "loader",
    "talos",
    "parser",
    "generator",
    "streaming"
  ]
}
