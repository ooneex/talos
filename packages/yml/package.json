{
  "name": "@talosjs/yml",
  "description": "YAML file loader and parser using Bun's built-in YAML support with generator-based streaming",
  "version": "1.1.0",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsgo --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/exception": "workspace:^",
    "@talosjs/http-status": "workspace:^"
  },
  "keywords": [
    "bun",
    "talos",
    "yaml",
    "yml",
    "parser",
    "loader",
    "generator"
  ]
}
