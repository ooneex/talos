{
  "name": "@talosjs/command",
  "description": "Command framework for building CLI commands with dependency injection, argument parsing, and execution logging",
  "version": "1.3.0",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsgo --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/app-env": "workspace:^",
    "@talosjs/container": "workspace:^",
    "@talosjs/exception": "workspace:^",
    "@talosjs/http-status": "workspace:^",
    "@talosjs/logger": "workspace:^",
    "@talosjs/utils": "workspace:^"
  },
  "devDependencies": {
    "@talosjs/types": "workspace:^"
  },
  "keywords": [
    "bun",
    "cli",
    "command",
    "talos",
    "typescript"
  ]
}
