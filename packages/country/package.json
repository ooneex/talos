{
  "name": "@talosjs/country",
  "description": "Country metadata library providing timezone data, ISO codes, and multi-language localization support for internationalized applications",
  "version": "1.1.0",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./en": {
      "import": {
        "types": "./dist/en.d.ts",
        "default": "./dist/en.js"
      }
    },
    "./fr": {
      "import": {
        "types": "./dist/fr.d.ts",
        "default": "./dist/fr.js"
      }
    },
    "./ro": {
      "import": {
        "types": "./dist/ro.d.ts",
        "default": "./dist/ro.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsgo --noEmit && bunx biome lint",
    "test": "bun test tests"
  },
  "dependencies": {
    "@vvo/tzdb": "^6.198.0"
  },
  "devDependencies": {
    "@talosjs/translation": "workspace:^"
  },
  "keywords": [
    "bun",
    "countries",
    "country",
    "i18n",
    "locale",
    "talos",
    "timezone",
    "typescript"
  ]
}
