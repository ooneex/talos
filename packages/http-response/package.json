{
  "name": "@talosjs/http-response",
  "description": "HTTP response builder with fluent API for setting status codes, headers, cookies, and streaming or buffered content delivery",
  "version": "1.1.0",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "compile": "tsc ./src/index.ts --declaration --emitDeclarationOnly --target ES2022 --moduleResolution bundler --outfile dist/index.d.ts",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsgo --noEmit && bunx biome lint",
    "test": "bun test tests"
  },
  "dependencies": {
    "@talosjs/app-env": "workspace:^",
    "@talosjs/http-header": "workspace:^",
    "@talosjs/http-status": "workspace:^"
  },
  "devDependencies": {},
  "keywords": [
    "bun",
    "cookies",
    "headers",
    "http",
    "http-response",
    "talos",
    "response",
    "typescript",
    "web"
  ]
}
