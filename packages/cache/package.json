{
  "name": "@talosjs/cache",
  "description": "High-performance caching layer with filesystem and Redis backends — features TTL expiration, auto-serialization, configurable size limits, and dependency injection integration",
  "version": "1.1.2",
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test tests",
    "build": "bunup",
    "fmt": "bunx biome check --write",
    "lint": "tsc --noEmit && bunx biome lint"
  },
  "dependencies": {
    "@talosjs/app-env": "workspace:^",
    "@talosjs/container": "workspace:^",
    "@talosjs/exception": "workspace:^",
    "@talosjs/http-status": "workspace:^"
  },
  "devDependencies": {},
  "keywords": [
    "bun",
    "cache",
    "caching",
    "memory",
    "talos",
    "redis",
    "storage",
    "typescript"
  ]
}
